<Window x:Class="ChatApp_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡 SecureShield Awareness System"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F0B">

    <Window.Resources>
        <Style x:Key="AgentBubble" TargetType="Border">
            <Setter Property="Background" Value="#5A189A"/>
            <Setter Property="CornerRadius" Value="15,15,4,15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="100,5,15,5"/>
        </Style>

        <Style x:Key="ShieldBubble" TargetType="Border">
            <Setter Property="Background" Value="#132613"/>
            <Setter Property="CornerRadius" Value="4,15,15,15"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="15,5,100,5"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#1B4D1B"/>
            <Setter Property="Foreground" Value="#4ADE80"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="85"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2D6A2D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1B4D1B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#5C1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#8B2020"/>
            <Setter Property="Width" Value="85"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B2020"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DrillButton" TargetType="Button">
            <Setter Property="Background" Value="#0D1A0D"/>
            <Setter Property="Foreground" Value="#86EFAC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#132613"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#4ADE80"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskButton" TargetType="Button">
            <Setter Property="Background" Value="#0D1A0D"/>
            <Setter Property="Foreground" Value="#86EFAC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#132613"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#4ADE80"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#2D6A2D"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#0D1A0D"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#2D6A2D" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuizOptionButton" TargetType="Button">
            <Setter Property="Background" Value="#0D1A0D"/>
            <Setter Property="Foreground" Value="#86EFAC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#2D6A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#132613"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#4ADE80"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#1B4D1B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#0D1A0D"
                BorderBrush="#2D6A2D"
                BorderThickness="0,0,0,1">
            <StackPanel Margin="20,15">
                <TextBlock FontFamily="Consolas"
                           FontSize="9"
                           Foreground="#4ADE80"
                           TextAlignment="Center"
                           FontWeight="Bold">
					<Run Text="╔════════════════════════════════════════════════════════════════════════════════╗" />
					<LineBreak />
					<Run Text="║   ___  ____  ____  _  _  ____  ____  ___  _  _  ____  ____  __    ____      ║" />
					<LineBreak />
					<Run Text="║  / __)( ___)/ ___)( )( )(  _ \( ___)/ __)( )( )(_  _)( ___)(  )  (  _ \     ║" />
					<LineBreak />
					<Run Text="║  \__ \ )__)( (__  )()(  )   / )__)  \__ \ )__(  )(   )__)  )(__   )(_) )     ║" />
					<LineBreak />
					<Run Text="║  (___/(____)\___)(____)(__)\_)(____)(___/(____)(__) (__)(__)(____)(____)     ║" />
					<LineBreak />
					<Run Text="║                        >> Protecting You in the Digital Age &lt;&lt;              ║" />
					<LineBreak />
					<Run Text="╚════════════════════════════════════════════════════════════════════════════════╝" />
                </TextBlock>

                <TextBlock Foreground="#6B7280"
                           FontSize="12"
                           TextAlignment="Center"
                           Margin="0,8,0,0">
					<Run Text="SecureShield Awareness System" Foreground="#4ADE80" FontWeight="Bold"/>
					<Run Text=" • "/>
					<Run Text="Protecting You in the Digital Age"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- NAVIGATION TABS -->
        <Border Grid.Row="1"
                Background="#0D1A0D"
                BorderBrush="#2D6A2D"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <Button x:Name="ChatTabButton"
                        Style="{StaticResource TabButton}"
                        Content="💬 Chat"
                        Foreground="#4ADE80"
                        Click="ChatTabButton_Click"/>
                <Button x:Name="TasksTabButton"
                        Style="{StaticResource TabButton}"
                        Content="📋 Tasks"
                        Click="TasksTabButton_Click"/>
                <Button x:Name="QuizTabButton"
                        Style="{StaticResource TabButton}"
                        Content="🎯 Quiz"
                        Click="QuizTabButton_Click"/>
                <Button x:Name="ActivityTabButton"
                        Style="{StaticResource TabButton}"
                        Content="📜 Activity Log"
                        Click="ActivityTabButton_Click"/>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Chat Panel -->
            <Border Grid.Column="0" Background="#0B0F0B">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ChatScrollViewer"
                                  Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#0B0F0B">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}"/>
                        </ScrollViewer.Resources>
                        <StackPanel x:Name="ChatPanel" Margin="15"/>
                    </ScrollViewer>

                    <!-- Input Bar -->
                    <Border Grid.Row="1"
                            Background="#0D1A0D"
                            Padding="15"
                            BorderBrush="#2D6A2D"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="InputTextBox"
                                     Grid.Column="0"
                                     Height="40"
                                     FontSize="14"
                                     Foreground="#86EFAC"
                                     Background="#0B0F0B"
                                     BorderBrush="#2D6A2D"
                                     BorderThickness="1"
                                     Padding="12,8"
                                     CaretBrush="#4ADE80"
                                     VerticalContentAlignment="Center"
                                     TextWrapping="Wrap"
                                     KeyDown="InputTextBox_KeyDown"/>

                            <Button x:Name="SendButton"
                                    Grid.Column="1"
                                    Style="{StaticResource ActionButton}"
                                    Content="📤 Send"
                                    Click="SendButton_Click"
                                    Margin="10,0,0,0"/>

                            <Button x:Name="ClearButton"
                                    Grid.Column="2"
                                    Style="{StaticResource DangerButton}"
                                    Content="🗑️ Clear"
                                    Click="ClearButton_Click"
                                    Margin="5,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Side Panel -->
            <Border Grid.Column="1"
                    Background="#0D1A0D"
                    BorderBrush="#2D6A2D"
                    BorderThickness="1,0,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="📋 Quick Actions"
                               Foreground="#4ADE80"
                               FontWeight="Bold"
                               FontSize="14"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <Button Content="🎯 Start Security Drill"
                                Style="{StaticResource TaskButton}"
                                Click="StartDrillButton_Click"
                                Margin="0,5"/>
                        <Button Content="📋 View Tasks"
                                Style="{StaticResource TaskButton}"
                                Click="ViewTasksButton_Click"
                                Margin="0,5"/>
                        <Button Content="📜 View Activity Log"
                                Style="{StaticResource TaskButton}"
                                Click="ViewActivityLogButton_Click"
                                Margin="0,5"/>
                        <Button Content="⭐ View Profile"
                                Style="{StaticResource TaskButton}"
                                Click="ViewProfileButton_Click"
                                Margin="0,5"/>
                        <Button Content="📚 Help Menu"
                                Style="{StaticResource TaskButton}"
                                Click="HelpButton_Click"
                                Margin="0,5"/>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="#0B0F0B"
                            BorderBrush="#1B4D1B"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="💡 Quick Tips"
                                       Foreground="#4ADE80"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="• Type 'add task: [description]' to create a task"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="• Type 'remind [days]' to set a reminder"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="• Type 'show tasks' to view all tasks"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="• Type 'drill' to start a security drill"
                                       Foreground="#6B7280"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- TASK PANEL -->
        <Border x:Name="TaskPanelBorder"
                Grid.Row="2"
                Background="#0B0F0B"
                BorderBrush="#2D6A2D"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📋 Task Management"
                           Foreground="#4ADE80"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0,0,0,15"/>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TaskInputTextBox"
                             Grid.Column="0"
                             Height="35"
                             FontSize="13"
                             Foreground="#86EFAC"
                             Background="#0D1A0D"
                             BorderBrush="#2D6A2D"
                             BorderThickness="1"
                             Padding="10,5"
                             CaretBrush="#4ADE80"
                             VerticalContentAlignment="Center"/>
                    <Button x:Name="AddTaskButton"
                            Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            Content="➕ Add Task"
                            Click="AddTaskButton_Click"
                            Margin="10,0,0,0"/>
                </Grid>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}"/>
                    </ScrollViewer.Resources>
                    <StackPanel x:Name="TaskListPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- QUIZ PANEL -->
        <Border x:Name="QuizPanelBorder"
                Grid.Row="2"
                Background="#0B0F0B"
                BorderBrush="#2D6A2D"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="🎯 Cybersecurity Quiz"
                           Foreground="#4ADE80"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="StartQuizButton"
                            Style="{StaticResource ActionButton}"
                            Content="▶️ Start Quiz"
                            Click="StartQuizButton_Click"
                            Width="100"/>
                    <TextBlock x:Name="QuizScoreText"
                               Foreground="#86EFAC"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="#0D1A0D"
                        BorderBrush="#2D6A2D"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="QuizQuestionText"
                                   Foreground="#86EFAC"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <StackPanel x:Name="QuizOptionsPanel"/>
                        <TextBlock x:Name="QuizFeedbackText"
                                   Foreground="#4ADE80"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="3"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}"/>
                    </ScrollViewer.Resources>
                    <TextBlock x:Name="QuizHistoryText"
                               Foreground="#6B7280"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ACTIVITY LOG PANEL -->
        <Border x:Name="ActivityLogPanelBorder"
                Grid.Row="2"
                Background="#0B0F0B"
                BorderBrush="#2D6A2D"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📜 Activity Log"
                           Foreground="#4ADE80"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="RefreshLogButton"
                            Style="{StaticResource ActionButton}"
                            Content="🔄 Refresh"
                            Click="RefreshLogButton_Click"
                            Width="100"/>
                    <Button x:Name="ClearLogButton"
                            Style="{StaticResource DangerButton}"
                            Content="🗑️ Clear"
                            Click="ClearLogButton_Click"
                            Width="100"
                            Margin="10,0,0,0"/>
                    <Button x:Name="ShowMoreLogButton"
                            Style="{StaticResource ActionButton}"
                            Content="📄 Show More"
                            Click="ShowMoreLogButton_Click"
                            Width="100"
                            Margin="10,0,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}"/>
                    </ScrollViewer.Resources>
                    <ItemsControl x:Name="ActivityLogItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D1A0D"
                                        BorderBrush="#1B4D1B"
                                        BorderThickness="0,0,0,1"
                                        Padding="10,8"
                                        Margin="0,2">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Timestamp}"
                                                   Foreground="#6B7280"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#86EFAC"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- DRILL PANEL -->
        <Border x:Name="DrillPanelBorder"
                Grid.Row="2"
                Background="#0D1A0D"
                BorderBrush="#5A189A"
                BorderThickness="0,1,0,0"
                Padding="20,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="DrillQuestionText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#86EFAC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                <StackPanel x:Name="DrillOptionsPanel"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock x:Name="DrillProgressText"
                               FontSize="11"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="DrillScoreText"
                               FontSize="11"
                               Foreground="#4ADE80"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>